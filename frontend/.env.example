# Frontend environment overrides (Vite). Copy to `.env.local` to customize.
#
# Backend target for the dev-server `/api` proxy. Only needed when running the
# React frontend on its own against a separately hosted backend; the bundled
# Tauri desktop app does not use this.
VITE_BACKEND_TARGET=http://localhost:8080

# Note: LLM API keys are NOT configured here. They are entered in the app's
# Model settings and stored locally — never committed to the repo.
#
# Backend-only knob (set as a real OS environment variable, not via this file):
#   STORE_SQLITE_PATH=/custom/path/agent-team.db
